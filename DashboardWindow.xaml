<Window x:Class="PomodoroApp.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Study Dashboard — Study Sanctuary"
        Height="720" Width="920"
        MinHeight="600" MinWidth="720"
        Background="#1E1E2E"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- sticky header with stats -->
            <RowDefinition Height="*"/>      <!-- scrollable body -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════
             HEADER — title + four stat cards
        ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#181825" Padding="32,22,32,22">
            <StackPanel>

                <TextBlock Text="Study Dashboard"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#CDD6F4"/>
                <TextBlock Text="Your Pomodoro history at a glance"
                           FontSize="12" Foreground="#585B70"
                           Margin="0,2,0,20"/>

                <!-- Stat cards row -->
                <StackPanel Orientation="Horizontal">

                    <Border Background="#313244" CornerRadius="10"
                            Padding="18,14" Margin="0,0,12,0" MinWidth="148">
                        <StackPanel>
                            <TextBlock Text="TOTAL SESSIONS"
                                       FontSize="10" FontWeight="SemiBold" Foreground="#585B70"/>
                            <TextBlock Text="{Binding TotalSessions}"
                                       FontSize="34" FontWeight="Bold" Foreground="#89B4FA"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#313244" CornerRadius="10"
                            Padding="18,14" Margin="0,0,12,0" MinWidth="148">
                        <StackPanel>
                            <TextBlock Text="TOTAL STUDY TIME"
                                       FontSize="10" FontWeight="SemiBold" Foreground="#585B70"/>
                            <TextBlock Text="{Binding TotalStudyTime}"
                                       FontSize="34" FontWeight="Bold" Foreground="#A6E3A1"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#313244" CornerRadius="10"
                            Padding="18,14" Margin="0,0,12,0" MinWidth="148">
                        <StackPanel>
                            <TextBlock Text="COMPLETION RATE"
                                       FontSize="10" FontWeight="SemiBold" Foreground="#585B70"/>
                            <TextBlock Text="{Binding CompletionRate}"
                                       FontSize="34" FontWeight="Bold" Foreground="#FAB387"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#313244" CornerRadius="10"
                            Padding="18,14" MinWidth="148">
                        <StackPanel>
                            <TextBlock Text="THIS WEEK"
                                       FontSize="10" FontWeight="SemiBold" Foreground="#585B70"/>
                            <TextBlock Text="{Binding WeeklySessions}"
                                       FontSize="34" FontWeight="Bold" Foreground="#CBA6F7"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             BODY — bar chart + session history
        ══════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,26,32,36">

                <!-- ── Section label: chart ──────────────────────────── -->
                <TextBlock Text="STUDY ACTIVITY — LAST 14 DAYS"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="#585B70" Margin="0,0,0,10"/>

                <!-- Chart card -->
                <Border Background="#181825" CornerRadius="12"
                        Padding="24,20,24,16" Margin="0,0,0,28">
                    <StackPanel>

                        <!-- Scrollable bar area (handles narrow windows gracefully) -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      PanningMode="HorizontalOnly">
                            <ItemsControl ItemsSource="{Binding BarData}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <!-- Horizontal row; VerticalAlignment=Bottom aligns short bars to the baseline -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="56" Margin="3,0">

                                            <!-- Fixed-height container — bar grows from the bottom -->
                                            <Grid Height="160">
                                                <StackPanel VerticalAlignment="Bottom">
                                                    <!-- Minutes label sits just above the bar -->
                                                    <TextBlock Text="{Binding ValueLabel}"
                                                               HorizontalAlignment="Center"
                                                               FontSize="9" Foreground="#A6ADC8"
                                                               Margin="0,0,0,3"/>
                                                    <!-- The bar itself -->
                                                    <Border Height="{Binding BarHeight}"
                                                            Background="{Binding BarBrush}"
                                                            CornerRadius="3,3,0,0"
                                                            Margin="10,0"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Baseline rule -->
                                            <Border Height="1" Background="#45475A"/>

                                            <!-- Date label below the baseline -->
                                            <TextBlock Text="{Binding DateLabel}"
                                                       HorizontalAlignment="Center"
                                                       FontSize="9" Foreground="#585B70"
                                                       TextAlignment="Center"
                                                       Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Legend -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,14,0,0">
                            <Border Width="9" Height="9" Background="#89B4FA"
                                    CornerRadius="2" VerticalAlignment="Center"/>
                            <TextBlock Text="Today" FontSize="10" Foreground="#585B70"
                                       Margin="4,0,16,0" VerticalAlignment="Center"/>

                            <Border Width="9" Height="9" Background="#74C7EC"
                                    CornerRadius="2" VerticalAlignment="Center"/>
                            <TextBlock Text="Past sessions" FontSize="10" Foreground="#585B70"
                                       Margin="4,0,16,0" VerticalAlignment="Center"/>

                            <Border Width="9" Height="9" Background="#313244"
                                    CornerRadius="2" VerticalAlignment="Center"/>
                            <TextBlock Text="No study" FontSize="10" Foreground="#585B70"
                                       Margin="4,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- ── Section label: history ─────────────────────────── -->
                <TextBlock Text="SESSION HISTORY"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="#585B70" Margin="0,0,0,10"/>

                <!-- Empty state — shown only when TotalSessions == 0 -->
                <Border CornerRadius="12" Padding="40,36" Margin="0,0,0,8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#181825"/>
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TotalSessions}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="No sessions recorded yet"
                                   FontSize="16" Foreground="#45475A"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Complete a Pomodoro to see your history here."
                                   FontSize="12" Foreground="#313244"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Session cards list -->
                <ItemsControl ItemsSource="{Binding Sessions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#181825" CornerRadius="10"
                                    Padding="18,14" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Topic -->
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="{Binding Topic}"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="#CDD6F4"/>

                                    <!-- Mood + status badges (right-aligned, span rows 0–1) -->
                                    <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top">
                                        <Border Background="{Binding MoodBrush}"
                                                CornerRadius="10" Padding="10,3">
                                            <TextBlock Text="{Binding Mood}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#1E1E2E"/>
                                        </Border>
                                        <Border Background="{Binding StatusBrush}"
                                                CornerRadius="10" Padding="10,3"
                                                Opacity="0.80" Margin="0,5,0,0">
                                            <TextBlock Text="{Binding StatusLabel}"
                                                       FontSize="10"
                                                       Foreground="#1E1E2E"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Date · Time · Duration -->
                                    <StackPanel Grid.Row="1" Grid.Column="0"
                                                Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock Text="{Binding DateDisplay}"
                                                   FontSize="11" Foreground="#585B70"/>
                                        <TextBlock Text=" · " FontSize="11" Foreground="#45475A"/>
                                        <TextBlock Text="{Binding TimeDisplay}"
                                                   FontSize="11" Foreground="#585B70"/>
                                        <TextBlock Text=" · " FontSize="11" Foreground="#45475A"/>
                                        <TextBlock Text="{Binding Duration}"
                                                   FontSize="11" Foreground="#585B70"/>
                                    </StackPanel>

                                    <!-- Notes (hidden when empty) -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                               Text="{Binding Notes}"
                                               FontSize="12" Foreground="#A6ADC8"
                                               TextWrapping="Wrap"
                                               Margin="0,10,60,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasNotes}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Window>
