<Window x:Class="PomodoroApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Study Sanctuary"
        Height="680" Width="460"
        MinHeight="580" MinWidth="400"
        Background="#1E1E2E"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        FontFamily="Segoe UI">

    <Window.InputBindings>
        <KeyBinding Key="D"      Modifiers="Ctrl" Command="{Binding OpenDashboardCommand}"/>
        <KeyBinding Key="F11"                     Command="{Binding ToggleFullScreenCommand}"/>
        <KeyBinding Key="Escape"                  Command="{Binding ExitFullScreenCommand}"/>
    </Window.InputBindings>

    <!-- Root Grid holds two layers: normal UI + fullscreen overlay -->
    <Grid>

        <!-- ══════════════════════════════════════════════════════════════
             LAYER 1 — Normal app layout (hidden when fullscreen)
        ══════════════════════════════════════════════════════════════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFullScreen}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel Margin="30,24,30,28">

                <!-- ── App header ─────────────────────────────────────── -->

                <TextBlock Text="Study Sanctuary"
                           FontSize="24" FontWeight="Bold"
                           Foreground="#CDD6F4"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Pomodoro Focus Timer"
                           FontSize="12" Foreground="#585B70"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,16"/>

                <!-- ── Mode selector ──────────────────────────────────── -->

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="⏱  Work · 25 min"
                            Command="{Binding SetWorkModeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RoundButton}">
                                <Setter Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#585B70"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWorkMode}" Value="True">
                                        <Setter Property="Background" Value="#89B4FA"/>
                                        <Setter Property="Foreground" Value="#1E1E2E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Column="2" Content="☕  Rest · 5 min"
                            Command="{Binding SetRestModeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RoundButton}">
                                <Setter Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#585B70"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRestMode}" Value="True">
                                        <Setter Property="Background" Value="#A6E3A1"/>
                                        <Setter Property="Foreground" Value="#1E1E2E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- ── Timer display card ─────────────────────────────── -->

                <Border Background="#181825" CornerRadius="16"
                        Padding="20,28" Margin="0,0,0,20">
                    <Grid>

                        <!-- Timer + status — centred in the card -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TimeDisplay}"
                                       FontSize="84" FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="{Binding TimerForeground}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="13" Foreground="#A6ADC8"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center"
                                       Margin="0,10,0,0"/>
                        </StackPanel>

                        <!-- ⛶ Full-screen toggle button — top-right corner -->
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                Command="{Binding ToggleFullScreenCommand}"
                                ToolTip="Full screen  (F11)"
                                Content="⛶">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"    Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground"    Value="#45475A"/>
                                    <Setter Property="FontSize"      Value="18"/>
                                    <Setter Property="Cursor"        Value="Hand"/>
                                    <Setter Property="Padding"       Value="6,4"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bg"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bg" Property="Background" Value="#313244"/>
                                                        <Setter Property="Foreground" Value="#CDD6F4"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                    </Grid>
                </Border>

                <!-- ── Control buttons ────────────────────────────────── -->

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="▶  Start"
                            Command="{Binding StartCommand}"
                            Background="#A6E3A1"
                            Style="{StaticResource RoundButton}"/>
                    <Button Grid.Column="2" Content="⏸  Pause"
                            Command="{Binding PauseCommand}"
                            Background="#FAB387"
                            Style="{StaticResource RoundButton}"/>
                    <Button Grid.Column="4" Content="↺  Reset"
                            Command="{Binding ResetCommand}"
                            Background="#F38BA8"
                            Style="{StaticResource RoundButton}"/>
                </Grid>

                <!-- ── Study topic ─────────────────────────────────────── -->

                <TextBlock Text="STUDY TOPIC" Style="{StaticResource LabelText}"/>

                <Border Style="{StaticResource InputBorder}">
                    <Grid>
                        <TextBlock Text="What are you studying today?"
                                   Foreground="#585B70" FontSize="13"
                                   Margin="10,8,10,8"
                                   IsHitTestVisible="False" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Topic}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding Topic, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputBox}"/>
                    </Grid>
                </Border>

                <!-- ── Mood selector ──────────────────────────────────── -->

                <TextBlock Text="CURRENT MOOD" Style="{StaticResource LabelText}"/>

                <Border Style="{StaticResource InputBorder}">
                    <ComboBox ItemsSource="{Binding Moods}"
                              SelectedItem="{Binding SelectedMood}"
                              Padding="10,8" FontSize="13"
                              Foreground="#CDD6F4" BorderThickness="0">
                        <ComboBox.Background>
                            <SolidColorBrush Color="#313244"/>
                        </ComboBox.Background>
                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"       Color="#313244"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"    Color="#45475A"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#CDD6F4"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"   Color="#CDD6F4"/>
                        </ComboBox.Resources>
                    </ComboBox>
                </Border>

                <!-- ── Notes ──────────────────────────────────────────── -->

                <TextBlock Text="SESSION NOTES" Style="{StaticResource LabelText}"/>

                <Border Style="{StaticResource InputBorder}">
                    <Grid>
                        <TextBlock Text="Jot down thoughts, questions, or goals…"
                                   Foreground="#585B70" FontSize="13"
                                   Margin="10,8,10,8"
                                   IsHitTestVisible="False" VerticalAlignment="Top">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Notes}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="100" VerticalContentAlignment="Top"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>

                <!-- ── Dashboard button ───────────────────────────────── -->

                <Button Content="📊  View Dashboard"
                        Command="{Binding OpenDashboardCommand}"
                        Style="{StaticResource RoundButton}"
                        Background="#313244" Foreground="#CDD6F4"
                        Margin="0,0,0,12"/>

                <!-- ── Footer hint ────────────────────────────────────── -->

                <TextBlock Text="Session is saved automatically when the timer completes."
                           FontSize="11" Foreground="#45475A"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center"/>

            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════════════════════════════════════════════════════
             LAYER 2 — Full-screen overlay (visible only when fullscreen)
        ══════════════════════════════════════════════════════════════ -->
        <Grid Background="#1E1E2E">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFullScreen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <!-- Centred timer block -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- Mode label -->
                <TextBlock Text="{Binding ModeLabel}"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="#585B70"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>

                <!-- Giant countdown -->
                <TextBlock Text="{Binding TimeDisplay}"
                           FontSize="220" FontWeight="Bold"
                           FontFamily="Consolas"
                           Foreground="{Binding TimerForeground}"
                           HorizontalAlignment="Center"/>

                <!-- Status message -->
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="18" Foreground="#A6ADC8"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Margin="0,16,0,40"/>

                <!-- Timer controls — usable without leaving full screen -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="▶  Start" Command="{Binding StartCommand}"
                            Background="#A6E3A1" Style="{StaticResource RoundButton}"
                            Width="130" Margin="0,0,12,0"/>
                    <Button Content="⏸  Pause" Command="{Binding PauseCommand}"
                            Background="#FAB387" Style="{StaticResource RoundButton}"
                            Width="130" Margin="0,0,12,0"/>
                    <Button Content="↺  Reset" Command="{Binding ResetCommand}"
                            Background="#F38BA8" Style="{StaticResource RoundButton}"
                            Width="130"/>
                </StackPanel>

            </StackPanel>

            <!-- Exit hint — pinned to bottom -->
            <TextBlock Text="Press F11 or Escape to exit full screen"
                       VerticalAlignment="Bottom" HorizontalAlignment="Center"
                       Foreground="#313244" FontSize="11"
                       Margin="0,0,0,24"/>

        </Grid>

    </Grid>
</Window>
